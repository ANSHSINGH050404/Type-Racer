{
  "name": "type-racer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,worker -c cyan,magenta \"next dev\" \"npm run dev:worker\"",
    "dev:next": "next dev",
    "dev:worker": "wrangler dev -c worker/wrangler.toml --port 8787",
    "dev:party": "npm run dev:worker",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run build",
    "deploy:worker": "wrangler deploy -c worker/wrangler.toml",
    "deploy:party": "npm run deploy:worker"
  },
  "dependencies": {
    "nanoid": "^6.0.0",
    "next": "16.2.10",
    "partysocket": "^1.3.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260718.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "partykit": "^0.0.115",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.112.0"
  }
}
